---
import { themes } from '../themes';
import { ClientRouter } from 'astro:transitions';
import '../index.css';

interface Props {
  themeId: string;
}

const { themeId } = Astro.props;
const activeTheme = themes.find(t => t.id === themeId) || themes[0];
const title = `Omni-Compress | ${activeTheme.person} Mode`;
const description = activeTheme.strings.desc;
---

<!doctype html>
<html lang={activeTheme.id}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/omni-compress/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />

    {/* Production-only: coi-serviceworker adds COOP/COEP headers via SW so
        SharedArrayBuffer is available for @ffmpeg/core-mt (AVIF encoding).
        Dev uses a Vite plugin middleware instead (see astro.config.mjs) because
        coi-serviceworker's reload-to-register cycle races with Vite's
        dep-optimization reload, causing an infinite loop. */}
    {import.meta.env.PROD && (
      <>
        <script is:inline>
          window.coi = {
            shouldRegister: function () { return !window.crossOriginIsolated; },
            quiet: true,
          };
        </script>
        <script src="/omni-compress/coi-serviceworker.js" is:inline></script>
      </>
    )}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dharanish-v.github.io/omni-compress/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://dharanish-v.github.io/omni-compress/og-social-preview.svg" />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="640" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://dharanish-v.github.io/omni-compress/og-social-preview.svg" />

    <script is:inline>
      // Apply theme colors to root early to prevent flash
      const applyTheme = (themeId) => {
        // Need to duplicate a minimal version of themes here or inject it
        // For SSG, we can inject the CSS variables directly in a style tag below
      };
    </script>
    <style is:inline define:vars={{
      'theme-bg': activeTheme.colors.bg,
      'theme-text': activeTheme.colors.text,
      'theme-primary': activeTheme.colors.primary,
      'theme-primary-text': activeTheme.colors.primaryText,
      'theme-secondary': activeTheme.colors.secondary,
      'theme-accent': activeTheme.colors.accent,
      'theme-accent-text': activeTheme.colors.accentText,
      'theme-border': activeTheme.colors.border,
      'theme-shape1': activeTheme.colors.shape1,
      'theme-shape2': activeTheme.colors.shape2,
      'theme-shape3': activeTheme.colors.shape3,
      'theme-card-bg': activeTheme.colors.cardBg,
      'theme-card-alt': activeTheme.colors.cardAlt,
      'theme-card-alt-text': activeTheme.colors.cardAltText,
      'theme-shadow': activeTheme.colors.shadow,
    }}>
      html, body {
        overflow-x: hidden;
      }
      :root {
        --theme-bg: var(--theme-bg);
        --theme-text: var(--theme-text);
        --theme-primary: var(--theme-primary);
        --theme-primary-text: var(--theme-primary-text);
        --theme-secondary: var(--theme-secondary);
        --theme-accent: var(--theme-accent);
        --theme-accent-text: var(--theme-accent-text);
        --theme-border: var(--theme-border);
        --theme-shape1: var(--theme-shape1);
        --theme-shape2: var(--theme-shape2);
        --theme-shape3: var(--theme-shape3);
        --theme-card-bg: var(--theme-card-bg);
        --theme-card-alt: var(--theme-card-alt);
        --theme-card-alt-text: var(--theme-card-alt-text);
        --theme-shadow: var(--theme-shadow);
      }
    </style>
  </head>
  <body class={`pattern-${activeTheme.colors.pattern}`}>
    <slot />
  </body>
</html>
