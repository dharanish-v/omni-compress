{
  "name": "@dharanish/omni-compress",
  "version": "1.1.4",
  "description": "Smart-routing media compression library. Automatically selects the fastest engine — native Web APIs, FFmpeg Wasm, or OS binaries — for images and audio in browsers and Node.js.",
  "author": "Dharanish V",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dharanish-v/omni-compress.git",
    "directory": "packages/omni-compress"
  },
  "homepage": "https://github.com/dharanish-v/omni-compress#readme",
  "bugs": {
    "url": "https://github.com/dharanish-v/omni-compress/issues"
  },
  "keywords": [
    "compression",
    "image",
    "audio",
    "media",
    "ffmpeg",
    "wasm",
    "webassembly",
    "webcodecs",
    "offscreencanvas",
    "webp",
    "avif",
    "opus",
    "mp3",
    "flac",
    "convert",
    "encoder",
    "web-worker",
    "zero-copy",
    "isomorphic",
    "browser",
    "node"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./workers/*": {
      "import": "./dist/workers/*.js",
      "require": "./dist/workers/*.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.10"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
