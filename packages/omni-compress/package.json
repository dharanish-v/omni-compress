{
  "name": "@dharanish/omni-compress",
  "version": "2.0.0",
  "description": "Universal compression and archiving library. Smart-routes media (images/audio) via fastest engines (Web APIs, FFmpeg Wasm) and provides isomorphic ZIP archiving for any file type.",
  "author": "Dharanish V",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dharanish-v/omni-compress.git",
    "directory": "packages/omni-compress"
  },
  "homepage": "https://dharanish-v.github.io/omni-compress/",
  "bugs": {
    "url": "https://github.com/dharanish-v/omni-compress/issues"
  },
  "keywords": [
    "compression",
    "archiving",
    "zip",
    "archive",
    "fflate",
    "deflate",
    "batch",
    "image",
    "audio",
    "media",
    "ffmpeg",
    "wasm",
    "webassembly",
    "webcodecs",
    "offscreencanvas",
    "webp",
    "avif",
    "opus",
    "mp3",
    "flac",
    "convert",
    "encoder",
    "web-worker",
    "zero-copy",
    "isomorphic",
    "browser",
    "node"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./workers/*": {
      "import": "./dist/workers/*.js",
      "require": "./dist/workers/*.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "NODE_ENV=production tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@jsquash/avif": "^2.1.1",
    "fflate": "^0.8.2"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@vitest/browser": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "playwright": "^1.58.2",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18"
  }
}
