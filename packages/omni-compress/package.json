{
  "name": "omni-compress",
  "version": "2.3.10",
  "description": "Image, audio, and video compression for browser and Node.js. OffscreenCanvas fast path, FFmpeg Wasm fallback, Web Worker threading. Compress JPEG, PNG, WebP, AVIF, MP3, Opus, FLAC, MP4, WebM.",
  "author": "Dharanish V",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dharanish-v/omni-compress.git",
    "directory": "packages/omni-compress"
  },
  "homepage": "https://dharanish-v.github.io/omni-compress/",
  "bugs": {
    "url": "https://github.com/dharanish-v/omni-compress/issues"
  },
  "keywords": [
    "image-compression",
    "compress-image",
    "image-optimizer",
    "image-resize",
    "audio-compressor",
    "video-compression",
    "client-side-compression",
    "before-upload",
    "media-optimizer",
    "compression",
    "archiving",
    "zip",
    "archive",
    "fflate",
    "deflate",
    "batch",
    "image",
    "audio",
    "video",
    "media",
    "ffmpeg",
    "wasm",
    "webassembly",
    "webcodecs",
    "offscreencanvas",
    "webp",
    "avif",
    "opus",
    "mp3",
    "flac",
    "convert",
    "encoder",
    "web-worker",
    "zero-copy",
    "isomorphic",
    "browser",
    "node"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./compat": {
      "types": "./dist/compat/compressor.d.ts",
      "import": "./dist/compat/compressor.js",
      "require": "./dist/compat/compressor.cjs"
    },
    "./workers/*": {
      "import": "./dist/workers/*.js",
      "require": "./dist/workers/*.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "NODE_ENV=production tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "size": "size-limit",
    "clean": "rm -rf dist",
    "docs": "typedoc",
    "bench": "node bench/image-benchmark.mjs",
    "bench:browser": "node bench/browser-benchmark.mjs"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/core-mt": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "@jsquash/avif": "^2.1.1",
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/oxipng": "^2.3.0",
    "fflate": "^0.8.2"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "@size-limit/file": "^12.0.1",
    "@types/node": "^20.12.7",
    "@vitest/browser": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "jimp": "^1.6.1",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "size-limit": "^12.0.1",
    "tsup": "^8.0.2",
    "typedoc": "^0.28.18",
    "typescript": "^5.4.5",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "size-limit": [
    {
      "name": "Main entry (ESM)",
      "path": "dist/index.js",
      "limit": "20 KB",
      "gzip": true
    },
    {
      "name": "Main entry (CJS)",
      "path": "dist/index.cjs",
      "limit": "20 KB",
      "gzip": true
    },
    {
      "name": "Audio worker",
      "path": "dist/workers/audio.worker.js",
      "limit": "10 KB",
      "gzip": true
    },
    {
      "name": "Video worker",
      "path": "dist/workers/video.worker.js",
      "limit": "10 KB",
      "gzip": true
    },
    {
      "name": "Image worker (includes AVIF encoder)",
      "path": "dist/workers/image.worker.js",
      "limit": "35 KB",
      "gzip": true
    }
  ]
}
